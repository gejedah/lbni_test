-- No. | No. SO | Tipe SO 
-- | Qty | Tanggal | Jam | Kode Pelanggan | Nama Pelanggan | Kode Salesman | Nama Salesman |
-- Kategori Kargo | Asuransi | Tagihan Asuransi | Keterangan SO 
-- | Jadwal Kapal | Kode Kapal
-- | Tanggal Rencana Berangkat (ETD) | Wilayah Muat | Kode Partner Muat | Partner Muat 
-- | Wilayah Bongkar | Kode Partner Bongkar | Partner Bongkar | Harga Jual | Tanggal Otorisasi

select
	ROW_NUMBER() OVER (ORDER BY so.id_s_o  asc ) as 'No',
	so.no_s_o as 'No SO', 
	so.tipe as 'Tipe SO',
	so.qty as 'Qty',
	so.tanggal as 'Tanggal',
	so.jam as 'Jam',
	pelanggan.kode_pelanggan as 'Kode Pelanggan',
	pelanggan.nama as 'Nama Pelanggan',
	sales.kode_salesman as 'Kode Salesman',
	sales.nama as 'Nama Salesman',
	kk.nama_kategori_kargo as 'kategori kargo' ,
	case 
		when so.ada_asuransi = 1 then 'YA'
		else ''
	end as Asuransi,
	case
		when so.tagihan_asuransi is not null then so.tagihan_asuransi
		else ""
	end as 'Tagihan Asuransi',
	so.keterangan as "Keterangan So",
	CONCAT_WS(' ', kapal.nama_kapal , ' V. ',  jk.no_voyage )    as "Jadwal Kapal",
		kapal.kode_kapal as 'Kode Kapal',
		jk.rencana_berangkat_etd as "Tanggal Rencana Berangkat (ETD)",
	wm.nama_wilayah as "Wilayah Muat",
	COALESCE( pm.kode, '')  as "Kode Partner Muat",
	COALESCE(pm.nama, '') as "Partner Muat" ,
	COALESCE(wb.nama_wilayah, '') as "Wilayah Bongkar",
	COALESCE(pb.kode, '') as "Kode Partner Bongkar",
	COALESCE(pb.nama, '') as "Partner Bongkar",
	case
		when soohj.otorisasi_harga_jual is not null then soohj.otorisasi_harga_jual
		else so.harga_jual
	end as "Harga Jual",
	soohj.tanggal_otorisasi as "Tanggal Otorisasi"
from
	s_o so
left join pelanggan pelanggan
	on
	pelanggan.id_pelanggan = so.id_pelanggan
left join salesman sales
	on
	sales.id_salesman = so.id_salesman
left join kategori_kargo kk 
	on
	kk.id_kategori_kargo = so.id_kategori_kargo
left join jadwal_kapal jk 
	on
	jk.id_jadwal_kapal = so.id_jadwal_kapal
left join kapal as kapal
on
	kapal.id_kapal = jk.id_kapal
left join partner as pm
	on
	so.id_partner_muat = pm.id_partner
left join partner as pb
	on
	so.id_partner_bongkar = pb.id_partner
left join wilayah wm
	on
	jk.id_wilayah_muat = wm.id_wilayah
left join wilayah wb
	on
	wb.id_wilayah = jk.id_wilayah_bongkar
left join s_o_otorisasi_harga_jual soohj 
	on
	soohj.id_s_o = so.id_s_o
;